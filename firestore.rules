rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role == 'admin';
    }

    // Match the reports collection
    match /scam_reports/{reportId} {
      // READ: Allow authenticated users to view reports
      allow read: if isAuthenticated();
      
      // CREATE: Allow anyone to submit a new report (Anonymous reporting)
      allow create: if true;
      
      // UPDATE: Securely allow interaction (Voting, Flagging, Viewing)
      allow update: if 
        // 1. Allow updating ONLY specific counter fields (for anonymous users)
        (request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['helpful_votes', 'flag_count', 'trust_score', 'views', 'status'])) 
        ||
        // 2. OR allow full updates if the user is an Admin
        isAdmin();
      
      // DELETE: Only allow admins to delete reports
      allow delete: if isAdmin();
    }

    // Match the safe_companies collection
    match /safe_companies/{companyId} {
      allow read: if true;
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // OSINT Intelligence Feeds: Allow public read access for real-time telemetry
    match /threat_intel_feeds/{threatId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Safety alias for OSINT threats
    match /osint_threats/{threatId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // admin_users collection
    match /admin_users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    // api_keys collection
    match /api_keys/{keyId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    
    // payment_requests collection
    match /payment_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Default deny for other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
