# ── Database Configuration ────────────────────────────────────────────
# PostgreSQL connection string (asyncpg driver required for application)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/scamsentry

# ── Redis Cache Configuration ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Third-Party Threat Intelligence Keys ──────────────────────────────
# Google Safe Browsing API Key (v4 matches check)
GOOGLE_SAFE_BROWSING_API_KEY=your-google-safe-browsing-api-key

# ── Security Configuration ────────────────────────────────────────────
# JWT signing key used to issue admin tokens (change in production)
API_SECRET_KEY=change-me-in-production

# One-time bootstrap credential for POST /api/v1/admin/login
ADMIN_API_KEY=change-me-in-production

# JWT algorithm (default: HS256)
JWT_ALGORITHM=HS256

# JWT token expiry in hours (default: 24)
JWT_EXPIRY_HOURS=24

# ── Application Environment ───────────────────────────────────────────
# "development" enables engine query prints and SQLAlchemy debug logging
ENVIRONMENT=development
